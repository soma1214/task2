{% extends "../layouts/base.njk" %}

{% block title %}BootstrapLab · About{% endblock %}

{% block content %}
<!-- About Hero -->
<section class="about-hero text-white py-5">
  <div class="container py-4">
    <div class="row">
      <div class="col-lg-8 mx-auto text-center">
        <h1 class="display-4 fw-bold">About This Project</h1>
        <p class="lead opacity-75">Bootstrap 5 UI exploration & page design — internship task</p>
      </div>
    </div>
  </div>
</section>

<!-- Main Content -->
<section class="py-5">
  <div class="container">
    <div class="row g-5">
      <div class="col-lg-6">
        <h2 class="fw-semibold">What we built</h2>
        <p class="text-muted">This project demonstrates the extraction and remixing of high-quality Bootstrap 5 UI patterns. We combined components like navbars, cards, carousels, forms, and footers into original, visually appealing pages.</p>
        <ul class="list-unstyled mt-4">
          <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> 3 full pages: Home, About, Contact</li>
          <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> Fully responsive (desktop, tablet, mobile)</li>
          <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> Working contact form with validation</li>
          <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> Clean, well-indented code</li>
        </ul>
      </div>
      <div class="col-lg-6">
        <div class="bg-white p-4 rounded-4 shadow-sm">
          <h2 class="fw-semibold">Tech Stack</h2>
          <div class="d-flex flex-wrap gap-3 mt-3">
            <span class="badge bg-primary p-3 fs-6">HTML5</span>
            <span class="badge bg-secondary p-3 fs-6">CSS3</span>
            <span class="badge bg-info p-3 fs-6">Bootstrap 5</span>
            <span class="badge bg-dark p-3 fs-6">Nunjucks</span>
            <span class="badge bg-warning p-3 fs-6">Vite</span>
          </div>
          <hr />
          <h5 class="mt-3"><i class="bi bi-clock-history me-2"></i>Process</h5>
          <p class="text-muted small">Explored Bootstrap docs → collected components → designed pages → tested responsiveness → deployed via Netlify.</p>
        </div>
      </div>
    </div>

    <!-- Skills Cards -->
    <h2 class="fw-semibold mt-5 pt-3 text-center">Key Skills Practiced</h2>
    <div class="row g-4 mt-2">
      <div class="col-md-4">
        <div class="card team-card h-100 border-0 shadow-sm">
          <div class="card-body text-center">
            <i class="bi bi-layout-three-columns display-4 text-primary"></i>
            <h5 class="card-title mt-2">Layout Composition</h5>
            <p class="card-text text-muted">Combining components into cohesive page structures.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card team-card h-100 border-0 shadow-sm">
          <div class="card-body text-center">
            <i class="bi bi-palette display-4 text-primary"></i>
            <h5 class="card-title mt-2">Visual Appeal</h5>
            <p class="card-text text-muted">Consistent spacing, colors, and modern design.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card team-card h-100 border-0 shadow-sm">
          <div class="card-body text-center">
            <i class="bi bi-phone display-4 text-primary"></i>
            <h5 class="card-title mt-2">Responsiveness</h5>
            <p class="card-text text-muted">Mobile-first with Bootstrap utility classes.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}